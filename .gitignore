# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# Firebase admin credentials — never commit
scripts/serviceAccountKey.json
# Firebase Hosting deploy cache
.firebase/
# Local default account (personal ID number)
scripts/defaultUser.txt
# Firebase project config — points at the live database (rules are open)
src/firebase-config.ts

# typescript
*.tsbuildinfo

example

# generated native folders
/ios
/android
